# CAR-bench agent-under-test image (Track 1 & Track 2).
# A lightweight A2A server: model-written Python runs in a coroutine bridge and
# emits official evaluator tool calls. Decoupled from the evaluator (no car-bench).
#
# Build (from repo root):
#   docker build -f Dockerfile.agent -t car-bench-agent:local .
# Run (all model config via env; binds 0.0.0.0):
#   docker run --rm -p 8080:8080 \
#     -e CAR_AGENT_MODEL_PROVIDER=cerebras -e CAR_AGENT_MODEL=gpt-oss-120b \
#     -e CEREBRAS_API_KEY=... -e CAR_AGENT_SKILL=car_domain_120b.md \
#     car-bench-agent:local

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8080

WORKDIR /app

# 0) System deps. curl is required by the harness-generated compose healthcheck
#    (test: ["CMD","curl","-f",".../agent-card.json"]) that gates
#    depends_on: service_healthy. The slim base omits it; the official images
#    use a non-slim base that already ships it.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# 1) Install runtime deps first for better layer caching.
COPY agent-requirements.txt /app/agent-requirements.txt
RUN pip install --no-cache-dir -r /app/agent-requirements.txt

# 2) Copy ONLY what the agent needs: the package (code + bundled JSON schemas +
#    Skills/) and the two shared modules that live at src/ level.
COPY src/track_1_agent_coroutine_under_test /app/src/track_1_agent_coroutine_under_test
COPY src/logging_utils.py /app/src/logging_utils.py
COPY src/turn_metrics.py /app/src/turn_metrics.py

# Drop privileges.
RUN useradd --create-home --uid 10001 agent && chown -R agent:agent /app
USER agent

EXPOSE 8080

# All model configuration (provider, model id, API keys, base URL, reasoning
# effort, temperature, tool mode, skill file) is read from env vars by config.py.
# The server is the ENTRYPOINT; runtime args come from CMD for a plain
# `docker run`, or from the harness-generated compose `command:` (which appends
# --host/--port/--card-url) that OVERRIDES CMD. Exec-form ENTRYPOINT+CMD (not
# `sh -c`) is required so those args reach argparse directly. This matches the
# official evaluator image's ENTRYPOINT+CMD contract. No model CLI flags here
# -> pure env-driven configuration.
ENTRYPOINT ["python", "/app/src/track_1_agent_coroutine_under_test/server.py"]
CMD ["--host", "0.0.0.0", "--port", "8080"]
